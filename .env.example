# ledekranfiyatal.com - Ortam degiskenleri
# Bu dosyayi .env.local olarak kopyalayip degerleri doldurun.

# --- Supabase (Postgres + veri katmani) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Retell AI (sesli asistan + telefon) ---
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=
# Webhook imza dogrulamasi (bos birakilirsa RETELL_API_KEY kullanilir)
RETELL_WEBHOOK_SECRET=

# --- Cagri modu ---
# mock  = Retell yok, admin'den simule et (tamamen ucretsiz)
# web   = Retell web call (mikrofon, $10 kredi — varsayilan test modu)
# phone = Gercek telefon aramasi (Twilio + RETELL_FROM_NUMBER gerekli)
# Bos birakilirsa: telefon numarasi varsa phone, sadece Retell varsa web, yoksa mock
CALL_MODE=web

# Es zamanli aranacak maksimum tedarikci sayisi (DB ayari yoksa fallback)
MAX_CONCURRENT_CALLS=5

# --- Admin paneli ---
ADMIN_PASSWORD=
# Cookie imzalama icin rastgele uzun bir gizli anahtar
ADMIN_SESSION_SECRET=

# Uygulamanin public URL'i (webhook ve mutlak linkler icin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Eski/opsiyonel: harici teklif webhook'u
QUOTE_WEBHOOK_URL=
